<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- WELCOME -->
    <LinearLayout
        android:id="@+id/screenWelcome"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="संपर्क"
            android:textSize="56sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="हे अॅप तुमच्या फोनमधील सर्व इंग्रजी संपर्क नावे आपोआप मराठीत बदलेल."
            android:textSize="18sp"
            android:textColor="#444444"
            android:gravity="center"
            android:layout_marginBottom="64dp" />

        <Button
            android:id="@+id/btnStart"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:text="सुरू करा"
            android:textSize="20sp" />
    </LinearLayout>

    <!-- PERMISSION DENIED -->
    <LinearLayout
        android:id="@+id/screenPermissionDenied"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="परवानगी आवश्यक आहे"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="संपर्क नावे बदलण्यासाठी हे अॅप तुमच्या संपर्कांमध्ये प्रवेश करणे आवश्यक आहे. कृपया सेटिंग्जमध्ये परवानगी द्या."
            android:textSize="17sp"
            android:textColor="#444444"
            android:gravity="center"
            android:layout_marginBottom="48dp" />

        <Button
            android:id="@+id/btnOpenSettings"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:text="सेटिंग्ज उघडा"
            android:textSize="18sp" />
    </LinearLayout>

    <!-- SCANNING -->
    <LinearLayout
        android:id="@+id/screenScanning"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="नावे बदलत आहे…"
            android:textSize="20sp"
            android:textColor="#444444"
            android:gravity="center" />
    </LinearLayout>

    <!-- SCAN COMPLETE -->
    <LinearLayout
        android:id="@+id/screenScanComplete"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvScanCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A"
            android:gravity="center"
            android:layout_marginBottom="48dp" />

        <Button
            android:id="@+id/btnDone"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:text="ठीक आहे"
            android:textSize="20sp" />
    </LinearLayout>

    <!-- MAIN — ACTIVE (rollback) -->
    <LinearLayout
        android:id="@+id/screenActive"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp"
        android:visibility="gone">

        <Button
            android:id="@+id/btnRollback"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:text="इंग्रजी नावे परत आणा"
            android:textSize="18sp" />
    </LinearLayout>

    <!-- MAIN — INACTIVE (scan) -->
    <LinearLayout
        android:id="@+id/screenInactive"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp"
        android:visibility="gone">

        <Button
            android:id="@+id/btnScan"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:text="मराठीत रूपांतरित करा"
            android:textSize="18sp" />
    </LinearLayout>

</FrameLayout>
